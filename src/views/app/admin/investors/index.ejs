<% layout("layouts/main") %>

<style>
  /* =========================
     Investors index (scoped)
     ========================= */
  .invPage {
    width: 100%;
    max-width: 100%;
    margin: 0 auto;
  }
  @media (max-width: 980px) {
    .invPage { width: 95%; }
  }

  .invHeader {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 14px;
    flex-wrap: wrap;
  }
  .invHeader h1 { margin: 0; }
  .invHeader p { margin-top: 6px; }

  .invActions {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    align-items: center;
  }

  .panel.invPanel { padding: 18px; }

  .invSectionTitle {
    margin: 0;
    font-size: 16px;
    font-weight: 800;
    color: #0f172a;
  }
  .invSectionHint {
    margin-top: 6px;
    color: rgba(15, 23, 42, 0.65);
    font-size: 13px;
  }

  /* Table wrapper */
  .invTableWrap {
    width: 100%;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    border-radius: 16px;
  }

  /* Table */
  .invTable {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    min-width: 1020px;
  }

  .invTable thead th {
    text-align: left !important;
    font-size: 12px;
    letter-spacing: 0.02em;
    color: rgba(15, 23, 42, 0.65);
    font-weight: 800;
    padding: 10px 14px;
    border-bottom: 1px solid rgba(0,0,0,0.08);
    white-space: nowrap;
  }

  .invTable tbody td {
    text-align: left !important;
    vertical-align: top;
    padding: 14px 14px;
    border-bottom: 1px solid rgba(0,0,0,0.06);
  }

  .invTable tbody tr:hover td {
    background: rgba(255,255,255,0.55);
  }

  .invCellTitle {
    font-weight: 800;
    color: #0f172a;
    line-height: 1.2;
  }

  .invCellSub {
    margin-top: 5px;
    color: rgba(15, 23, 42, 0.62);
    font-size: 12px;
    line-height: 1.35;
  }

  .invMono {
    font-variant-numeric: tabular-nums;
    font-feature-settings: "tnum";
  }

  .invActionsCol {
    text-align: right !important;
    white-space: nowrap;
    min-width: 220px;
  }
  .invActionsCol .btn { margin-left: 8px; }

  @media (max-width: 820px) {
    .invTable { min-width: 920px; }
  }
</style>

<div class="invPage">
  <div class="invHeader">
    <div>
      <h1>Investors</h1>
      <p class="muted">Manage investors and pre-investors. Use “View” to see all investor details.</p>
    </div>

    <div class="invActions">
      <a class="btn btn-secondary" href="/admin/investors/new?role=PREINVESTOR">Add pre-investor</a>
      <a class="btn btn-primary" href="/admin/investors/new?role=INVESTOR">Add investor</a>
    </div>
  </div>

  <!-- =======================
       Investors
       ======================= -->
  <div class="panel invPanel" style="margin-top: 14px;">
    <div>
      <h3 class="invSectionTitle">Investors</h3>
      <div class="invSectionHint">
        General view only: type, name, business, total shares. (Email + full details are inside “View”.)
      </div>
    </div>

    <% if (!investors || !investors.length) { %>
      <p class="muted" style="margin-top:12px;">No investors yet.</p>
    <% } else { %>
      <div class="invTableWrap" style="margin-top:14px;">
        <table class="invTable">
          <thead>
            <tr>
              <th style="width: 10%;">Type</th>
              <th style="width: 20%;">Name</th>
              <th style="width: 30%;">Business</th>
              <th style="width: 15%;">Total shares</th>
              <th style="width: 15%;"></th>
            </tr>
          </thead>
          <tbody>
            <% investors.forEach(u => { %>
              <% const sh = u.shareholdingProfile || null; %>
              <% const type = sh ? sh.shareholdingType : null; %>
              <% const business = (sh && sh.shareholdingType === "BUSINESS" && sh.businessName) ? sh.businessName : ""; %>
              <% const displayName = sh
                ? ([sh.contactFirstName, sh.contactLastName].filter(Boolean).join(" ") || (u.name || ""))
                : (u.name || "");
              %>

              <tr>
                <td>
                  <% if (type) { %>
                    <span class="pill"><%= type %></span>
                  <% } else { %>
                    <span class="pill pill-warn">MISSING</span>
                  <% } %>
                </td>

                <td>
                  <div class="invCellTitle"><%= displayName || "-" %></div>
                </td>

                <td>
                  <% if (business) { %>
                    <div class="invCellTitle" style="font-weight:800;"><%= business %></div>
                  <% } else { %>
                    <span class="muted">-</span>
                  <% } %>
                </td>

                <td class="invMono">
                  <% if (sh) { %>
                    <div class="invCellTitle"><%= Number(sh.sharesTotal || 0).toLocaleString("en-AU") %></div>
                  <% } else { %>
                    <span class="muted">-</span>
                  <% } %>
                </td>

                <td class="invActionsCol">
                  <a class="btn btn-secondary btn-sm" href="/admin/investors/<%= u.id %>">View</a>
                  <a class="btn btn-secondary btn-sm" href="/admin/investors/<%= u.id %>/edit">Edit</a>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>

  <!-- =======================
       Pre-investors
       ======================= -->
  <div class="panel invPanel" style="margin-top: 14px;">
    <h3 class="invSectionTitle">Pre-investors</h3>
    <div class="invSectionHint">Pre-investor accounts can be edited or deleted.</div>

    <% if (!preinvestors || !preinvestors.length) { %>
      <p class="muted" style="margin-top:12px;">No pre-investors yet.</p>
    <% } else { %>
      <div class="invTableWrap" style="margin-top:14px;">
        <table class="invTable" style="min-width: 1120px;">
          <thead>
            <tr>
              <th style="width: 30%;">Email</th>
              <th style="width: 260px;">Name</th>
              <th style="width: 160px;">Account</th>
              <th style="width: 220px;">Instrument</th>
              <th style="width: 240px;">Last login</th>
              <th style="width: 240px;"></th>
            </tr>
          </thead>
          <tbody>
            <% preinvestors.forEach(u => { %>
              <% const lastInst = (u.investorInstruments && u.investorInstruments.length) ? u.investorInstruments[0] : null; %>

              <tr>
                <td>
                  <div class="invCellTitle"><%= u.email %></div>
                </td>
                <td>
                  <div class="invCellTitle"><%= u.name || "-" %></div>
                </td>
                <td>
                  <% if (u.isActive) { %>
                    <span class="pill pill-ok">ACTIVE</span>
                  <% } else { %>
                    <span class="pill pill-warn">INACTIVE</span>
                  <% } %>
                </td>
                <td>
                  <% if (lastInst) { %>
                    <div class="invCellTitle"><%= lastInst.instrumentRef %></div>
                    <div class="invCellSub">
                      <span class="pill"><%= lastInst.type %></span>
                      <span class="pill <%= lastInst.status === "CONVERTED" ? "pill-ok" : (lastInst.status === "CANCELLED" ? "pill-warn" : "") %>">
                        <%= lastInst.status %>
                      </span>
                    </div>
                  <% } else { %>
                    <span class="muted">Standard (no instrument)</span>
                  <% } %>
                </td>
                <td class="invCellSub" style="margin-top:0;">
                  <%= u.lastLoginAt ? new Date(u.lastLoginAt).toLocaleString() : "-" %>
                </td>
                <td class="invActionsCol">
                  <a class="btn btn-secondary btn-sm" href="/admin/investors/<%= u.id %>/edit">Edit</a>

                  <form method="post" action="/admin/investors/<%= u.id %>/delete" style="display:inline; margin:0;"
                    onsubmit="return confirm('Delete this PRE-INVESTOR? This cannot be undone.');">
                    <button class="btn btn-danger btn-sm" type="submit">Delete</button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>
</div>
