<% layout("layouts/main") %>

<%
  const sh = (typeof shareholding !== "undefined" && shareholding) ? shareholding : (user.shareholdingProfile || null);
  const safe = (v) => (v === null || typeof v === "undefined" || String(v).trim() === "" ? "-" : String(v));

  const fmtInt = (n) => {
    try {
      const num = Number(n || 0);
      return new Intl.NumberFormat("en-AU", { maximumFractionDigits: 0 }).format(num);
    } catch { return String(n ?? "0"); }
  };

  const fmtDec = (v) => {
    if (v === null || typeof v === "undefined") return "-";
    const s = String(v);
    if (!s.includes(".")) return s;
    return s.replace(/(\.\d*?[1-9])0+$/,"$1").replace(/\.0+$/,"");
  };
%>

<div style="display:flex; justify-content:space-between; align-items:center; gap:12px; flex-wrap:wrap;">
  <a class="btn btn-secondary" href="/admin/investors">← Back</a>

  <div style="display:flex; gap:10px; flex-wrap:wrap;">
    <a class="btn btn-secondary" href="/admin/investors/<%= user.id %>/edit">Edit</a>
  </div>
</div>

<div class="panel" style="margin-top: 12px;">
  <div style="display:flex; justify-content:space-between; align-items:flex-start; gap:12px; flex-wrap:wrap;">
    <div>
      <h1 style="margin:0;">Investor profile</h1>
      <p class="muted" style="margin-top:6px;">Full details for this account (read-only).</p>
    </div>

    <div style="display:flex; gap:10px; align-items:center; flex-wrap:wrap;">
      <% if (sh) { %>
        <span class="pill"><%= sh.shareholdingType %></span>
      <% } else { %>
        <span class="pill pill-warn">NO SHAREHOLDING PROFILE</span>
      <% } %>

      <span class="pill <%= user.isActive ? "pill-ok" : "pill-warn" %>"><%= user.isActive ? "ACTIVE" : "INACTIVE" %></span>
    </div>
  </div>

  <hr style="border:none; border-top:1px solid rgba(0,0,0,0.08); margin: 16px 0;" />

  <h3 style="margin:0 0 10px;">Account</h3>
  <div class="grid" style="grid-template-columns: 1fr 1fr; gap: 14px;">
    <div>
      <div class="muted small">Login email</div>
      <div style="font-weight:700;"><%= safe(user.email) %></div>
    </div>
    <div>
      <div class="muted small">Name</div>
      <div style="font-weight:700;"><%= safe(user.name) %></div>
    </div>
    <div>
      <div class="muted small">Role</div>
      <div style="font-weight:700;"><%= safe(user.role) %></div>
    </div>
    <div>
      <div class="muted small">Last login</div>
      <div style="font-weight:700;"><%= user.lastLoginAt ? new Date(user.lastLoginAt).toLocaleString() : "-" %></div>
    </div>
  </div>

  <hr style="border:none; border-top:1px solid rgba(0,0,0,0.08); margin: 16px 0;" />

  <h3 style="margin:0 0 10px;">Contact</h3>
  <% if (!sh) { %>
    <p class="muted">No shareholding profile exists for this investor yet.</p>
  <% } else { %>
    <div class="grid" style="grid-template-columns: 1fr 1fr; gap: 14px;">
      <div>
        <div class="muted small">Contact name</div>
        <div style="font-weight:700;"><%= [sh.contactFirstName, sh.contactLastName].filter(Boolean).join(" ") || "-" %></div>
      </div>
      <div>
        <div class="muted small">Contact email</div>
        <div style="font-weight:700;"><%= safe(sh.contactEmail) %></div>
      </div>
      <div>
        <div class="muted small">Contact phone</div>
        <div style="font-weight:700;"><%= safe(sh.contactPhone) %></div>
      </div>
      <div>
        <div class="muted small">Business name</div>
        <div style="font-weight:700;"><%= (sh.shareholdingType === "BUSINESS") ? safe(sh.businessName) : "-" %></div>
      </div>
    </div>

    <hr style="border:none; border-top:1px solid rgba(0,0,0,0.08); margin: 16px 0;" />

    <h3 style="margin:0 0 10px;">Shareholding</h3>
    <div class="grid" style="grid-template-columns: 1fr 1fr; gap: 14px;">
      <div>
        <div class="muted small">Total shares</div>
        <div style="font-weight:800; font-size:18px;"><%= fmtInt(sh.sharesTotal) %></div>
      </div>
      <div>
        <div class="muted small">Currency</div>
        <div style="font-weight:700;"><%= safe(sh.currency || "AUD") %></div>
      </div>
      <div>
        <div class="muted small">Price per share</div>
        <div style="font-weight:700;"><%= fmtDec(sh.pricePerShare) %></div>
      </div>
      <div>
        <div class="muted small">Unpaid per share</div>
        <div style="font-weight:700;"><%= sh.unpaidPerShare ? fmtDec(sh.unpaidPerShare) : "-" %></div>
      </div>
    </div>

    <hr style="border:none; border-top:1px solid rgba(0,0,0,0.08); margin: 16px 0;" />

    <h3 style="margin:0 0 10px;">Address</h3>
    <div class="grid" style="grid-template-columns: 1fr 1fr; gap: 14px;">
      <div style="grid-column: 1 / -1;">
        <div class="muted small">Address line 1</div>
        <div style="font-weight:700;"><%= safe(sh.addressLine1) %></div>
      </div>
      <div style="grid-column: 1 / -1;">
        <div class="muted small">Address line 2</div>
        <div style="font-weight:700;"><%= safe(sh.addressLine2) %></div>
      </div>
      <div>
        <div class="muted small">Suburb / City</div>
        <div style="font-weight:700;"><%= safe(sh.suburbOrCity) %></div>
      </div>
      <div>
        <div class="muted small">State / Region</div>
        <div style="font-weight:700;"><%= safe(sh.stateOrRegion) %></div>
      </div>
      <div>
        <div class="muted small">Postcode</div>
        <div style="font-weight:700;"><%= safe(sh.postcode) %></div>
      </div>
      <div>
        <div class="muted small">Country</div>
        <div style="font-weight:700;"><%= safe(sh.country || "AU") %></div>
      </div>
    </div>
  <% } %>
</div>
