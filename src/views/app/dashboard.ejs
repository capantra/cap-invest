<% layout("layouts/main") %>

<h1>Dashboard</h1>
<p class="muted">Welcome <%= user.name || user.email %>.</p>

<% if (user.role === 'PREINVESTOR' && instruments && instruments.length > 0) { %>
  <!-- Pre-Investor Instruments -->
  <div class="panel" style="margin-top:14px;">
    <h2 style="margin:0 0 20px;">Your Instruments</h2>
    
    <% instruments.forEach((instrument) => { %>
      <div style="padding:20px;margin-bottom:14px;background:rgba(59,130,246,0.05);border-radius:8px;border:1px solid rgba(59,130,246,0.15);">
        <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:14px;margin-bottom:12px;flex-wrap:wrap;">
          <div>
            <div style="font-size:18px;font-weight:bold;color:#0f172a;margin-bottom:4px;">
              <%= instrument.instrumentRef %>
            </div>
            <div class="muted" style="font-size:14px;">
              <%= instrument.type %> 
              <% if (instrument.discountPercent) { %>
                • <%= instrument.discountPercent %>% discount
              <% } %>
            </div>
          </div>
          <div style="<%= instrument.status === 'OUTSTANDING' ? 'background:rgba(0,151,117,0.1);border:1px solid rgba(0,151,117,0.2);' : instrument.status === 'CONVERTED' ? 'background:rgba(59,130,246,0.1);border:1px solid rgba(59,130,246,0.2);' : 'background:rgba(107,114,128,0.1);border:1px solid rgba(107,114,128,0.2);' %>padding:6px 14px;border-radius:20px;font-size:12px;font-weight:bold;">
            <%= instrument.status %>
          </div>
        </div>
        
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:14px;margin-top:14px;">
          <div>
            <div class="muted" style="font-size:12px;margin-bottom:4px;">Investment Amount</div>
            <div style="font-size:20px;font-weight:bold;color:#009775;">
              $<%= (instrument.purchaseAmountCents / 100).toLocaleString('en-AU', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %>
            </div>
          </div>
          
          <div>
            <div class="muted" style="font-size:12px;margin-bottom:4px;">Signed Date</div>
            <div style="font-size:16px;font-weight:600;">
              <%= new Date(instrument.signedAt).toLocaleDateString('en-AU', { year: 'numeric', month: 'short', day: 'numeric' }) %>
            </div>
          </div>
          
          <% if (instrument.convertedAt) { %>
            <div>
              <div class="muted" style="font-size:12px;margin-bottom:4px;">Converted Date</div>
              <div style="font-size:16px;font-weight:600;">
                <%= new Date(instrument.convertedAt).toLocaleDateString('en-AU', { year: 'numeric', month: 'short', day: 'numeric' }) %>
              </div>
            </div>
          <% } %>
        </div>
        
        <% if (instrument.notes) { %>
          <div style="margin-top:14px;padding-top:14px;border-top:1px solid rgba(59,130,246,0.2);">
            <div class="muted" style="font-size:12px;margin-bottom:4px;">Notes</div>
            <div style="font-size:14px;color:rgba(15,23,42,0.8);"><%= instrument.notes %></div>
          </div>
        <% } %>
      </div>
    <% }) %>
  </div>
<% } %>

<% if (shareholding) { %>
  <!-- Shareholding Summary -->
  <div class="panel" style="margin-top:14px;">
    <h2 style="margin:0 0 20px;">Your Shareholding</h2>
    
    <div style="display:grid;grid-template-columns:repeat(auto-fit, minmax(250px, 1fr));gap:20px;margin-bottom:20px;">
      <!-- Total Shares -->
      <div style="padding:20px;background:rgba(0,151,117,0.05);border-radius:8px;border:1px solid rgba(0,151,117,0.15);">
        <div class="muted" style="font-size:14px;margin-bottom:8px;">Total Shares</div>
        <div style="font-size:32px;font-weight:bold;color:#009775;">
          <%= shareholding.sharesTotal.toLocaleString() %>
        </div>
      </div>
      
      <!-- Price Per Share -->
      <div style="padding:20px;background:rgba(59,130,246,0.05);border-radius:8px;border:1px solid rgba(59,130,246,0.15);">
        <div class="muted" style="font-size:14px;margin-bottom:8px;">Blended Average Price Per Share</div>
        <div style="font-size:32px;font-weight:bold;color:#3B82F6;">
          $<%= averagePricePerShare.toFixed(4) %>
        </div>
      </div>
      
      <!-- Total Value -->
      <div style="padding:20px;background:rgba(168,85,247,0.05);border-radius:8px;border:1px solid rgba(168,85,247,0.15);">
        <div class="muted" style="font-size:14px;margin-bottom:8px;">Total Shareholding Value</div>
        <div style="font-size:32px;font-weight:bold;color:#A855F7;">
          $<%= (shareholding.sharesTotal * averagePricePerShare).toLocaleString('en-AU', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %>
        </div>
      </div>
    </div>

    <!-- Additional Share Purchase Button -->
    <div style="border-top:1px solid rgba(0,0,0,0.1);padding-top:20px;">
      <button type="button" class="btn btn-primary" onclick="openSharePurchaseModal()">
        Purchase Additional Shares
      </button>
    </div>
  </div>

  <!-- Share Purchase Modal -->
  <div id="share-purchase-modal" style="display:none;position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,0.5);z-index:1000;align-items:center;justify-content:center;">
    <div style="background:white;border-radius:12px;box-shadow:0 20px 25px rgba(0,0,0,0.15);max-width:500px;width:90%;max-height:90vh;overflow-y:auto;">
      <!-- Modal Header -->
      <div style="padding:20px;border-bottom:1px solid rgba(0,0,0,0.1);display:flex;justify-content:space-between;align-items:center;">
        <h2 style="margin:0;">Purchase Additional Shares</h2>
        <button type="button" onclick="closeSharePurchaseModal()" style="background:none;border:none;font-size:24px;cursor:pointer;color:#666;">×</button>
      </div>
      
      <!-- Modal Body -->
      <div style="padding:20px;">
        <form id="share-purchase-form" style="display:grid;gap:12px;">
          <div>
            <label for="shares-input">Number of Shares</label>
            <input 
              type="number" 
              id="shares-input"
              name="shares"
              min="1" 
              step="1"
              required
              placeholder="e.g., 100"
              style="width:100%;padding:8px;border:1px solid #ddd;border-radius:6px;font-size:14px;"
            />
          </div>
          
          <div>
            <label for="notes-input">Additional Notes (Optional)</label>
            <textarea 
              id="notes-input"
              name="notes"
              placeholder="Any additional information about your request..."
              style="width:100%;min-height:100px;padding:8px;border:1px solid #ddd;border-radius:6px;font-size:14px;font-family:inherit;"
            ></textarea>
          </div>
          
          <div id="purchase-result" style="display:none;"></div>
          
          <div style="display:flex;gap:10px;justify-content:flex-end;margin-top:10px;">
            <button type="button" onclick="closeSharePurchaseModal()" class="btn btn-secondary">
              Cancel
            </button>
            <button type="submit" class="btn btn-primary">
              Submit Request
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
<% } %>

<!-- Updates & Documents -->
<div class="grid" style="margin-top:20px;">
  <div class="panel">
    <h3>Updates</h3>
    <p class="muted">Latest company updates and board packs.</p>
    <a class="btn btn-primary" href="/updates">View updates</a>
  </div>

  <div class="panel">
    <h3>Data Room</h3>
    <p class="muted">Documents, decks, and reports.</p>
    <a class="btn btn-primary" href="/documents">Open data room</a>
  </div>
</div>

<script>
function openSharePurchaseModal() {
  document.getElementById('share-purchase-modal').style.display = 'flex';
}

function closeSharePurchaseModal() {
  document.getElementById('share-purchase-modal').style.display = 'none';
  document.getElementById('share-purchase-form').reset();
  document.getElementById('purchase-result').style.display = 'none';
}

// Close modal when clicking outside
document.getElementById('share-purchase-modal')?.addEventListener('click', (e) => {
  if (e.target.id === 'share-purchase-modal') {
    closeSharePurchaseModal();
  }
});

document.getElementById('share-purchase-form')?.addEventListener('submit', async (e) => {
  e.preventDefault();
  
  const btn = e.target.querySelector('button[type="submit"]');
  const shares = document.getElementById('shares-input').value;
  const notes = document.getElementById('notes-input').value;
  const resultDiv = document.getElementById('purchase-result');
  
  btn.disabled = true;
  btn.textContent = 'Submitting...';
  resultDiv.style.display = 'none';
  
  try {
    const response = await fetch('/dashboard/request-shares', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
      },
      body: JSON.stringify({ shares, notes }),
    });
    
    const data = await response.json();
    
    if (data.success) {
      resultDiv.style.display = 'block';
      resultDiv.innerHTML = `
        <div style="padding:14px;background:rgba(0,151,117,0.1);border-radius:8px;border:1px solid rgba(0,151,117,0.2);margin-bottom:15px;">
          <div style="display:flex;align-items:center;gap:8px;">
            <span style="font-size:18px;">✓</span>
            <div>
              <div style="font-weight:600;">Request Submitted</div>
              <div class="muted small">${data.message}</div>
            </div>
          </div>
        </div>
      `;
      document.getElementById('share-purchase-form').reset();
      
      // Close modal after 2 seconds
      setTimeout(() => {
        closeSharePurchaseModal();
      }, 2000);
    } else {
      resultDiv.style.display = 'block';
      resultDiv.innerHTML = `
        <div style="padding:14px;background:rgba(239,68,68,0.1);border-radius:8px;border:1px solid rgba(239,68,68,0.2);margin-bottom:15px;">
          <div style="font-weight:600;color:#DC2626;">Error</div>
          <div class="muted small">${data.error || 'Failed to submit request'}</div>
        </div>
      `;
    }
  } catch (error) {
    resultDiv.style.display = 'block';
    resultDiv.innerHTML = `
      <div style="padding:14px;background:rgba(239,68,68,0.1);border-radius:8px;border:1px solid rgba(239,68,68,0.2);margin-bottom:15px;">
        <div style="font-weight:600;color:#DC2626;">Error</div>
        <div class="muted small">${error.message}</div>
      </div>
    `;
  } finally {
    btn.disabled = false;
    btn.textContent = 'Submit Request';
  }
});
</script>
