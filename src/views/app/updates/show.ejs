<% layout("layouts/main") %>

<a class="btn btn-secondary" href="/updates">← Back</a>

<div class="panel" style="margin-top: 12px;">
  <div style="display:flex; gap:10px; flex-wrap:wrap; align-items:center;">
    <h1 style="margin:0;"><%= update.title %></h1>
    <% if (update.type) { %>
      <span class="pill"><%= update.type.name %></span>
    <% } %>
    <% if (update.investorOnly) { %>
      <span class="pill pill-warn">Investor only</span>
    <% } %>
  </div>

  <p class="muted" style="margin-top:8px;">
    Published <%= update.publishedAt ? new Date(update.publishedAt).toLocaleString() : "Draft" %>
  </p>

  <% if (update.tags && update.tags.length) { %>
    <div style="margin-top:10px; display:flex; gap:6px; flex-wrap:wrap;">
      <% update.tags.forEach(tagName => { %>
        <a class="pill" href="/updates?tag=<%= encodeURIComponent(tagName) %>"><%= tagName %></a>
      <% }) %>
    </div>
  <% } %>

  <% if (update.body) { %>
    <div style="margin-top:14px; white-space:pre-wrap;">
      <%= update.body %>
    </div>
  <% } %>

  <% if (update.attachments && update.attachments.length) { %>
    <div style="margin-top:18px;">
      <h3>Attachments</h3>
      <% update.attachments.forEach(a => { %>
        <div style="margin-bottom:20px;">
          <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;">
            <div>
              <strong><%= a.fileName %></strong>
              <div class="muted"><%= a.mimeType %> • <%= Math.round((a.sizeBytes || 0) / 1024) %> KB</div>
            </div>
            <a class="btn btn-secondary" href="/attachments/<%= encodeURIComponent(a.storageKey) %>" target="_blank" rel="noreferrer">
              Download
            </a>
          </div>
          <% if (a.mimeType === 'application/pdf') { %>
            <div style="border:1px solid rgba(0,0,0,0.1);border-radius:8px;overflow:hidden;">
              <iframe 
                src="/attachments/<%= encodeURIComponent(a.storageKey) %>" 
                style="width:100%;height:600px;border:none;"
                title="<%= a.fileName %>"
              ></iframe>
            </div>
          <% } %>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>
