<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title><%= (typeof title !== "undefined" && title) ? title : "Investor Portal" %></title>
  <link rel="stylesheet" href="/assets/styles.css" />
</head>

<body class="app">
  <% const hasUser = (typeof user !== "undefined" && user); %>
  <% const pageTitle = (typeof title !== "undefined" && title) ? title : "Investor Portal"; %>

  <% if (hasUser) { %>
    <!-- Mobile sidebar toggle -->
    <input id="nav-toggle" class="nav-toggle" type="checkbox" aria-hidden="true" />

    <aside class="sidebar" aria-label="Primary">
      <div class="sidebar__brand">
        <div class="brandtext">
          <img src="https://pub-1e587b8a735340e788c5a49ed8f83204.r2.dev/Brand/logo.png" height="auto" width="52%" alt="Capantra">
          <div class="brandsub">Investor Portal</div>
        </div>

        <label class="iconbtn sidebar__close" for="nav-toggle" title="Close menu" aria-label="Close menu">
          ✕
        </label>
      </div>

      <div class="sidebar__sectionLabel">Navigation</div>

      <div class="sidebar__nav" data-sidebar-nav>
        <%
          // ------------------------------------------------------------
          // Robust nav selection (NO file path passing, NO viewsRoot)
          // You may optionally set res.locals.navKey in routes.
          // Otherwise default by role.
          // Valid: "admin" | "investor" | "preinvestor"
          // ------------------------------------------------------------
          const role = user?.role || "INVESTOR";
          const key =
            (typeof navKey !== "undefined" && navKey)
              ? String(navKey)
              : (role === "ADMIN" ? "admin" : (role === "PREINVESTOR" ? "preinvestor" : "investor"));
        %>

        <% if (key === "admin") { %>
          <%- include("../partials/nav.admin.ejs") %>
        <% } else if (key === "preinvestor") { %>
          <%- include("../partials/nav.preinvestor.ejs") %>
        <% } else { %>
          <%- include("../partials/nav.investor.ejs") %>
        <% } %>
      </div>

      <div class="sidebar__footer">
        <div class="muted">Signed in as</div>
        <div class="sidebar__user">
          <div class="avatar"><%= (user.email || "U").slice(0,1).toUpperCase() %></div>
          <div class="sidebar__userText">
            <div class="strong"><%= user.name || user.email %></div>
            <div class="muted small"><%= user.email %></div>
          </div>
        </div>

        <div class="sidebar__footLinks">
          <a class="sidebar__footLink" href="/account">Account</a>
          <% if (user.role === "ADMIN") { %>
            <span class="dot">•</span>
            <a class="sidebar__footLink" href="/admin">Admin</a>
          <% } %>
          <span class="dot">•</span>
          <a class="sidebar__footLink sidebar__footLink--danger" href="/logout">Logout</a>
        </div>
      </div>
    </aside>

    <div class="layout">
      <header class="topbar">
        <div class="topbar__left">
          <label class="iconbtn topbar__hamburger" for="nav-toggle" title="Open menu" aria-label="Open menu">
            ☰
          </label>

          <div class="topbar__titles">
            <div class="topbar__title"><%= pageTitle %></div>
            <div class="topbar__subtitle">Secure portal • Audit logged</div>
          </div>
        </div>

        <div class="topbar__right">
          <%
            const roleLabel =
              user.role === "ADMIN" ? "Admin" :
              user.role === "INVESTOR" ? "Investor" :
              user.role === "PREINVESTOR" ? "Pre-Investor" :
              String(user.role || "User");
          %>

          <span class="pill <%= user.role === "INVESTOR" ? "pill-ok" : (user.role === "ADMIN" ? "pill-warn" : "pill-neutral") %>">
            <%= roleLabel %>
          </span>

          <div class="userMenu" data-user-menu>
            <button class="userMenu__btn" type="button" data-user-menu-btn aria-haspopup="true" aria-expanded="false">
              <span class="avatar avatar--sm"><%= (user.email || "U").slice(0,1).toUpperCase() %></span>
              <span class="userMenu__name"><%= user.name || user.email %></span>
              <span class="userMenu__chev">▾</span>
            </button>

            <div class="userMenu__panel" role="menu" aria-label="User menu" data-user-menu-panel>
              <div class="userMenu__meta">
                <div class="strong"><%= user.name || "Account" %></div>
                <div class="muted small"><%= user.email %></div>
              </div>

              <div class="menuSep"></div>

              <a class="menuItem" href="/account">Account</a>
              <a class="menuItem" href="/account/preferences">Email preferences</a>

              <% if (user.role === "ADMIN") { %>
                <div class="menuSep"></div>
                <a class="menuItem" href="/admin">Admin</a>
              <% } %>

              <div class="menuSep"></div>

              <a class="menuItem danger" href="/logout">Logout</a>
            </div>
          </div>
        </div>
      </header>

      <main class="content">
        <div class="content__inner">
          <%- body %>
        </div>
      </main>

      <footer class="footer footer--fixed">
        <div class="footer__inner">
          <div>© <%= new Date().getFullYear() %> Capantra. All rights reserved.</div>
          <div class="muted">Confidential</div>
        </div>
      </footer>
    </div>

    <div class="backdrop" aria-hidden="true" data-backdrop></div>

    <!-- Sidebar modernization helpers (safe + self-contained) -->
    <script>
      (function () {
        const navRoot = document.querySelector("[data-sidebar-nav]");
        if (navRoot) {
          const links = navRoot.querySelectorAll("a[href]");
          const path = window.location.pathname;

          function pickIcon(href, label) {
            const h = String(href || "").toLowerCase();
            const t = String(label || "").toLowerCase();

            if (h === "/dashboard" || t.includes("dashboard")) return "⌂";
            if (h.includes("/updates") || t.includes("update")) return "⎘";
            if (h.includes("/documents") || t.includes("data room") || t.includes("teaser")) return "▦";
            if (h.includes("/account") || t.includes("account")) return "⚙";
            if (h.startsWith("/admin") || t.includes("admin")) return "◆";
            if (h.includes("/investors") || t.includes("investor")) return "◈";
            if (h.includes("/instruments") || t.includes("instrument")) return "◎";
            if (t.includes("download") || h.endsWith(".csv")) return "⇩";
            if (t.includes("logout")) return "⟲";
            return "•";
          }

          links.forEach(function (a) {
            const href = a.getAttribute("href") || "";
            const label = (a.textContent || "").trim();

            const isActive =
              href === path ||
              (href !== "/" && href.length > 1 && path.startsWith(href));

            a.classList.add("sidebar__link");
            if (isActive) a.classList.add("is-active");

            if (!a.querySelector(".sidebar__icon")) {
              const icon = document.createElement("span");
              icon.className = "sidebar__icon";
              icon.setAttribute("aria-hidden", "true");
              icon.textContent = pickIcon(href, label);

              const text = document.createElement("span");
              text.className = "sidebar__text";
              text.textContent = label;

              a.textContent = "";
              a.appendChild(icon);
              a.appendChild(text);
            }
          });

          const hasList = navRoot.querySelector("ul, ol");
          if (!hasList) {
            const wrapper = document.createElement("div");
            wrapper.className = "sidebar__list";
            while (navRoot.firstChild) wrapper.appendChild(navRoot.firstChild);
            navRoot.appendChild(wrapper);
          }
        }

        const navToggle = document.getElementById("nav-toggle");
        const backdrop = document.querySelector("[data-backdrop]");
        const menuRoot = document.querySelector("[data-user-menu]");
        const menuBtn = document.querySelector("[data-user-menu-btn]");
        const menuPanel = document.querySelector("[data-user-menu-panel]");

        function closeSidebar() { if (navToggle) navToggle.checked = false; }
        function openMenu() {
          if (!menuRoot || !menuBtn || !menuPanel) return;
          menuRoot.classList.add("is-open");
          menuBtn.setAttribute("aria-expanded", "true");
        }
        function closeMenu() {
          if (!menuRoot || !menuBtn || !menuPanel) return;
          menuRoot.classList.remove("is-open");
          menuBtn.setAttribute("aria-expanded", "false");
        }
        function toggleMenu() { if (!menuRoot) return; menuRoot.classList.contains("is-open") ? closeMenu() : openMenu(); }

        if (backdrop) backdrop.addEventListener("click", function () { closeSidebar(); closeMenu(); });
        if (menuBtn) menuBtn.addEventListener("click", function (e) { e.preventDefault(); toggleMenu(); });

        document.addEventListener("click", function (e) {
          const t = e.target;
          if (!menuRoot) return;
          if (menuRoot.classList.contains("is-open")) {
            if (t instanceof Node && !menuRoot.contains(t)) closeMenu();
          }
        });

        document.addEventListener("keydown", function (e) {
          if (e.key === "Escape") { closeSidebar(); closeMenu(); }
        });

        if (navToggle) navToggle.addEventListener("change", function () { if (!navToggle.checked) closeMenu(); });
      })();
    </script>

    <style>
      .sidebar__sectionLabel{
        padding: 10px 16px 6px;
        font-size: 11px;
        letter-spacing: .12em;
        text-transform: uppercase;
        color: rgba(15, 23, 42, 0.55);
        font-weight: 800;
      }
      .sidebar__nav{ padding: 4px 10px 10px; }
      .sidebar__list{ display:flex; flex-direction:column; gap:6px; }
      .sidebar__link{
        display:flex; align-items:center; gap:10px;
        padding:10px 12px; border-radius:14px; text-decoration:none;
        color: rgba(15, 23, 42, 0.86); font-weight:700; line-height:1.1;
        border:1px solid rgba(0,0,0,0.06);
        background: rgba(255,255,255,0.35);
        transition: transform .08s ease, background .12s ease, border-color .12s ease;
        overflow:hidden;
      }
      .sidebar__link:hover{
        background: rgba(255,255,255,0.6);
        border-color: rgba(0,0,0,0.10);
        transform: translateY(-1px);
      }
      .sidebar__link.is-active{
        background: rgba(255,255,255,0.86);
        border-color: rgba(45, 212, 191, 0.55);
        box-shadow: 0 10px 26px rgba(2, 132, 199, 0.10);
      }
      .sidebar__icon{
        width:22px; height:22px; display:inline-flex; align-items:center; justify-content:center;
        border-radius:10px; font-size:12px; font-weight:900;
        color: rgba(15, 23, 42, 0.7);
        background: rgba(15, 23, 42, 0.05);
        flex: 0 0 auto;
      }
      .sidebar__text{ min-width:0; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
      .sidebar__footLinks{ margin-top:10px; display:flex; gap:8px; align-items:center; flex-wrap:wrap; font-size:12px; }
      .sidebar__footLink{ color: rgba(15, 23, 42, 0.65); text-decoration:none; font-weight:800; }
      .sidebar__footLink:hover{ text-decoration: underline; }
      .sidebar__footLink--danger{ color: rgba(239, 68, 68, 0.85); }
      .dot{ color: rgba(15, 23, 42, 0.25); }
      .sidebar__nav ul, .sidebar__nav ol{
        list-style:none; margin:0; padding:0;
        display:flex; flex-direction:column; gap:6px;
      }
      .sidebar__nav li{ margin:0; padding:0; }
      .sidebar__nav li > a{ width:100%; }
      @media (max-width: 820px){
        .sidebar__nav{ padding: 6px 10px 12px; }
        .sidebar__link{ padding: 12px 12px; border-radius: 16px; }
      }
    </style>

  <% } else { %>
    <main class="public">
      <div class="public__inner">
        <%- body %>
      </div>

      <footer class="publicFooter publicFooter--fixed">
        © <%= new Date().getFullYear() %> Capantra. All rights reserved.
      </footer>
    </main>
  <% } %>
</body>
</html>
