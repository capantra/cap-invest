<!doctype html>
<html>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Confidentiality Agreement</title>
  <link rel="stylesheet" href="/assets/styles.css" />
</head>
<body class="center">
  <div class="publicWrap" style="width: min(980px, 100%);">
    <div class="card wide">
      <h1><%= agreement.title %></h1>
      <p class="muted">Version <%= agreement.version %></p>

      <% if (flash) { %>
        <div class="flash <%= flash.type %>"><%= flash.message %></div>
      <% } %>

      <div class="agreement">
        <%- agreement.bodyHtml %>
      </div>

      <form method="post" action="/agreement/accept" style="margin-top:12px;">
        <label class="checkbox">
          <input type="checkbox" name="agree" required />
          I have read and agree to the Confidentiality &amp; Portal Access Agreement.
        </label>
        <button class="btn btn-primary" type="submit">I Agree</button>
      </form>

      <p class="muted small" style="margin-top:10px;">
        Accepted as: <%= user.email %>
      </p>
    </div>

    <div class="publicFooter">
      © <%= new Date().getFullYear() %> Capantra. All rights reserved.
    </div>
  </div>
</body>
</html>
